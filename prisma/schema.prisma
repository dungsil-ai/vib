generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RecurringFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  accounts  Account[]
  transactions Transaction[]
  budgets   Budget[]
  recurringTransactions RecurringTransaction[]
}

model Account {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  name      String
  code      String
  type      String
  description String?
  createdAt DateTime    @default(now())
  debitEntries  Entry[] @relation("DebitAccount")
  creditEntries Entry[] @relation("CreditAccount")
  budgets   Budget[]
  recurringDebitEntries  RecurringEntry[] @relation("RecurringDebitAccount")
  recurringCreditEntries RecurringEntry[] @relation("RecurringCreditAccount")

  @@unique([userId, code])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  description String
  entries     Entry[]
  createdAt   DateTime @default(now())

  @@index([userId, date(sort: Desc)])
}

model Entry {
  id              String      @id @default(cuid())
  transactionId   String
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  debitAccountId  String
  debitAccount    Account     @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId String
  creditAccount   Account     @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount          Decimal
  description     String?
  createdAt       DateTime    @default(now())

  @@index([transactionId])
  @@index([debitAccountId])
  @@index([creditAccountId])
}

model Budget {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  accountId String
  account   Account  @relation(fields: [accountId], references: [id])
  year      Int
  month     Int
  amount    Decimal
  createdAt DateTime @default(now())

  @@unique([userId, accountId, year, month])
  @@index([userId, year, month])
}

model RecurringTransaction {
  id          String               @id @default(cuid())
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  description String
  frequency   RecurringFrequency
  dayOfMonth  Int?
  monthOfYear Int?
  startDate   DateTime
  endDate     DateTime?
  nextRunAt   DateTime
  lastRunAt   DateTime?
  isActive    Boolean              @default(true)
  entries     RecurringEntry[]
  createdAt   DateTime             @default(now())

  @@index([userId, nextRunAt])
}

model RecurringEntry {
  id                     String               @id @default(cuid())
  recurringTransactionId String
  recurringTransaction   RecurringTransaction @relation(fields: [recurringTransactionId], references: [id], onDelete: Cascade)
  debitAccountId         String
  debitAccount           Account              @relation("RecurringDebitAccount", fields: [debitAccountId], references: [id])
  creditAccountId        String
  creditAccount          Account              @relation("RecurringCreditAccount", fields: [creditAccountId], references: [id])
  amount                 Decimal
  description            String?
  createdAt              DateTime             @default(now())

  @@index([recurringTransactionId])
}
